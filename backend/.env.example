# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/assignment_hub"

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET="change_me_to_a_long_random_string"

# How long a login session lasts (e.g. 7d, 24h)
JWT_EXPIRES_IN="7d"

# Server port
PORT=5000

# Frontend origin (required for CORS + cookies)
CLIENT_URL="http://localhost:5173"

# development | production
NODE_ENV="development"
